# Copy this file to .env and fill in real values for local development.
#
# Public frontend configuration consumed by Vite at build/dev time.
# These values identify the Cognito resources Terraform created; they are not
# secrets and are safe to expose in browser JavaScript.
VITE_AWS_REGION=eu-central-1
VITE_COGNITO_USER_POOL_ID=eu-central-1_example
VITE_COGNITO_USER_POOL_CLIENT_ID=exampleclientid

# Do not add an API Gateway URL here.
# The browser talks to the backend through the same CloudFront origin using
# relative /events paths, for example:
#   GET /events
#   POST /events/{event_id}/rsvp
