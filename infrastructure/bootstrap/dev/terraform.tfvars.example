# Copy to terraform.tfvars and adjust values as needed.
aws_region   = "eu-central-1"
project_name = "aws-serverless-events-platform"
environment  = "dev"

common_tags = {
  Project     = "aws-serverless-events-platform"
  Environment = "dev"
  Owner       = "platform"
}

# Optional explicit names:
# state_bucket_name = "aws-serverless-events-platform-dev-tf-state-xxxx"
# lock_table_name   = "aws-serverless-events-platform-dev-tf-lock"

